{
  "name": "la-cour-de-haut",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm db:migrate && next build",
    "start": "pnpm db:migrate && pnpm seed-owner && next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed-owner": "tsx scripts/seed-owner.mts",
    "seed-ical-sources": "tsx scripts/seed-ical-sources.mts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "doctor": "react-doctor --yes --no-telemetry ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/translate": "^9.4.2",
    "@marsidev/react-turnstile": "^1.5.2",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-form-nextjs": "^1.33.0",
    "@vercel/blob": "^2.4.1",
    "better-auth": "^1.6.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "intl-messageformat": "^11.2.8",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "node-ical": "^0.26.1",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "lefthook": "2.1.9",
    "prettier": "^3.8.4",
    "react-doctor": "0.5.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
