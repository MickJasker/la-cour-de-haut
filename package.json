{
  "name": "la-cour-de-haut",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm db:migrate && next build",
    "start": "pnpm db:migrate && pnpm seed-owner && next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate && pnpm run backfill-gallery-dimensions && pnpm run seed-property-settings && pnpm run seed-pages",
    "seed-owner": "tsx scripts/seed-owner.mts",
    "seed-ical-sources": "tsx scripts/seed-ical-sources.mts",
    "seed-property-settings": "tsx scripts/seed-property-settings.mts",
    "seed-pages": "tsx scripts/seed-pages.mts",
    "backfill-gallery-dimensions": "tsx scripts/backfill-gallery-dimensions.mts",
    "migrate-content-blocks-to-rich-text": "tsx scripts/migrate-content-blocks-to-rich-text.mts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "doctor": "react-doctor --yes --no-telemetry ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/translate": "^9.4.2",
    "@lexical/headless": "^0.46.0",
    "@lexical/html": "^0.46.0",
    "@lexical/link": "^0.46.0",
    "@lexical/list": "^0.46.0",
    "@lexical/react": "^0.46.0",
    "@lexical/rich-text": "^0.46.0",
    "@lexical/utils": "^0.46.0",
    "@marsidev/react-turnstile": "^1.5.3",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tanstack/react-form-nextjs": "^1.33.0",
    "@vercel/blob": "^2.5.0",
    "@vercel/functions": "^3.7.4",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "happy-dom": "^20.10.6",
    "intl-messageformat": "^11.2.9",
    "lexical": "^0.46.0",
    "libphonenumber-js": "^1.13.8",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "node-ical": "^0.26.1",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "resend": "^6.17.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/probe-image-size": "^7.2.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "lefthook": "2.1.9",
    "prettier": "^3.9.4",
    "probe-image-size": "^7.3.0",
    "react-doctor": "0.7.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
