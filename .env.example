# Database (Neon Postgres)
DATABASE_URL=postgresql://...

# Better Auth
BETTER_AUTH_SECRET=          # random 32+ char secret (generate with: openssl rand -base64 32)
BETTER_AUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM=noreply@lacourdehaut.fr

# Auto-translate (DeepL Free API)
DEEPL_API_KEY=

# Spam protection (Cloudflare Turnstile)
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Image storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# iCal export (set this to a long random token once, never change it)
# Used in the outbound .ics feed URL: /api/ical/{ICAL_EXPORT_TOKEN}.ics
ICAL_EXPORT_TOKEN=
