# =============================================================================
# Auto-provisioned by Vercel — run `vercel env pull .env.local` to get these
# =============================================================================

# Neon Postgres (via `vercel integration add neon`)
DATABASE_URL=                   # pooled connection (used by the app)
DATABASE_URL_UNPOOLED=          # direct connection (used by drizzle-kit push/migrate)
NEON_PROJECT_ID=
NEON_AUTH_BASE_URL=
VITE_NEON_AUTH_URL=

# Postgres aliases injected by Neon — only DATABASE_URL is used by this app,
# the rest are here for tools/ORMs that read PG* or POSTGRES_* conventions
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGPASSWORD=
PGDATABASE=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel Blob (via `vercel blob create-store ... --yes`)
BLOB_READ_WRITE_TOKEN=

# Set automatically by Vercel at runtime — do not set manually
VERCEL_OIDC_TOKEN=

# =============================================================================
# Set manually — generate locally, then push to Vercel with `vercel env add`
# =============================================================================

# Better Auth
BETTER_AUTH_SECRET=             # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000  # production: https://lacourdehaut.fr

# App base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000  # production: https://lacourdehaut.fr

# iCal export tokens are managed in /admin/ical/export — no env var needed.

# =============================================================================
# Set manually after creating external accounts
# =============================================================================

# Email (Resend) — verify lacourdehaut.fr sending domain before use
RESEND_API_KEY=re_...
RESEND_FROM=noreply@lacourdehaut.fr
OWNER_EMAIL=owner@lacourdehaut.fr  # booking request notifications go here

# Auto-translate — Google Cloud Translation API v3
# Service account JSON (minified to single line): IAM role "Cloud Translation API User"
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Spam protection (Cloudflare Turnstile — https://dash.cloudflare.com)
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
